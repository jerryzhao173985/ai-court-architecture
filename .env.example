# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=30

# LLM Connection Pooling and Performance Settings
LLM_CONNECTION_POOL_SIZE=10
LLM_CONNECT_TIMEOUT=10
LLM_READ_TIMEOUT=30

# LLM Retry Settings
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0

# LLM Rate Limiting (to prevent API quota exhaustion)
LLM_RATE_LIMIT_RPM=60
LLM_RATE_LIMIT_TPM=90000

# Luffa Bot Configuration - Multi-Bot Architecture
# Each trial agent can be a separate bot for realistic group chat experience

# Bot 1: Clerk (Procedural guidance and orchestration)
LUFFA_BOT_CLERK_UID=your_clerk_bot_uid
LUFFA_BOT_CLERK_SECRET=your_clerk_bot_secret

# Bot 2: Prosecution Barrister
LUFFA_BOT_PROSECUTION_UID=your_prosecution_bot_uid
LUFFA_BOT_PROSECUTION_SECRET=your_prosecution_bot_secret

# Bot 3: Defence Barrister
LUFFA_BOT_DEFENCE_UID=your_defence_bot_uid
LUFFA_BOT_DEFENCE_SECRET=your_defence_bot_secret

# Bot 4: Fact Checker
LUFFA_BOT_FACT_CHECKER_UID=your_fact_checker_bot_uid
LUFFA_BOT_FACT_CHECKER_SECRET=your_fact_checker_bot_secret

# Bot 5: Judge
LUFFA_BOT_JUDGE_UID=your_judge_bot_uid
LUFFA_BOT_JUDGE_SECRET=your_judge_bot_secret

# Bot 6: Witness 1 (first witness from case data)
# LUFFA_BOT_WITNESS_1_UID=your_witness_1_bot_uid
# LUFFA_BOT_WITNESS_1_SECRET=your_witness_1_bot_secret

# Bot 7: Witness 2 (second witness from case data)
# LUFFA_BOT_WITNESS_2_UID=your_witness_2_bot_uid
# LUFFA_BOT_WITNESS_2_SECRET=your_witness_2_bot_secret

# Bot 8: Defendant (the accused)
# LUFFA_BOT_DEFENDANT_UID=your_defendant_bot_uid
# LUFFA_BOT_DEFENDANT_SECRET=your_defendant_bot_secret

# Bot 9-10: AI Jurors (juror_1 = Evidence Purist, juror_2 = Sympathetic Doubter)
# LUFFA_BOT_JUROR_1_UID=your_juror_1_bot_uid
# LUFFA_BOT_JUROR_1_SECRET=your_juror_1_bot_secret
# LUFFA_BOT_JUROR_2_UID=your_juror_2_bot_uid
# LUFFA_BOT_JUROR_2_SECRET=your_juror_2_bot_secret

# Luffa API Configuration
LUFFA_API_ENDPOINT=https://apibot.luffa.im/robot
LUFFA_BOT_ENABLED=true

# Application Configuration
SESSION_TIMEOUT_HOURS=24
MAX_EXPERIENCE_MINUTES=20

# Admin Configuration
# Comma-separated list of Luffa user UIDs who can access admin commands (/metrics, /sessions)
VERITAS_ADMIN_UIDS=

# Session Storage Configuration
# Backend options: file, postgresql, mongodb
SESSION_STORAGE_BACKEND=file

# File Backend Settings (default)
SESSION_FILE_STORAGE_DIR=data/sessions

# PostgreSQL Backend Settings (optional)
# SESSION_POSTGRESQL_DSN=postgresql://user:password@localhost:5432/veritas
# SESSION_POSTGRESQL_TABLE=user_sessions
# SESSION_POSTGRESQL_POOL_MIN=10
# SESSION_POSTGRESQL_POOL_MAX=20

# MongoDB Backend Settings (optional)
# SESSION_MONGODB_CONNECTION_STRING=mongodb://localhost:27017
# SESSION_MONGODB_DATABASE=veritas
# SESSION_MONGODB_COLLECTION=user_sessions
# SESSION_MONGODB_POOL_SIZE=20

# Batching Settings (for high concurrency)
SESSION_BATCH_SIZE=10
SESSION_BATCH_INTERVAL=1.0
