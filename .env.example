# LLM Configuration
LLM_PROVIDER=openai  # or anthropic
LLM_API_KEY=your_api_key_here  # Or set OPENAI_API_KEY in your shell environment
LLM_MODEL=gpt-4o  # Default model for trial agents (active jurors use gpt-4o, lightweight use gpt-4o-mini)
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=30

# Luffa Platform Configuration
LUFFA_API_URL=https://api.luffa.bot
LUFFA_API_KEY=your_luffa_api_key_here
LUFFA_BOT_ENABLED=true
LUFFA_SUPERBOX_ENABLED=true
LUFFA_CHANNEL_ENABLED=true

# Application Configuration
SESSION_TIMEOUT_HOURS=24
MAX_EXPERIENCE_MINUTES=20
